generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model Product { id Int @id @default(autoincrement()) name String category String sales Int revenue Float }
model Order { id Int @id @default(autoincrement()) total Float createdAt DateTime @default(now()) }
model Customer { id Int @id @default(autoincrement()) source String returning Boolean }
